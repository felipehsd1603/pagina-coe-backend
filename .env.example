# ─── Server ──────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── Auth Mode ───────────────────────────────────────
# "mock" for local dev, "entra" for production
AUTH_MODE=mock

# ─── JWT Secret (OBRIGATORIO, min 32 chars) ─────────
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_generate_a_random_64char_hex_string_here
JWT_EXPIRES_IN=8h

# ─── CORS Origins (comma-separated) ─────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Database ────────────────────────────────────────
DATABASE_URL="sqlserver://localhost:1433;database=portal_aegea;user=sa;password=YOUR_DB_PASSWORD;encrypt=true;trustServerCertificate=true"
DB_SA_PASSWORD=YOUR_DB_PASSWORD

# ─── Microsoft Entra ID (production) ─────────────────
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# ─── CoE Data Source ─────────────────────────────────
# "dataverse" = API real do Dataverse (CoE Starter Kit)
# "local"     = Dados reais AEGEA (telemetria + fichas) - PADRAO
# "mock"      = Dados ficticios para demo
COE_DATA_SOURCE=local

# ─── Dataverse OData (quando COE_DATA_SOURCE=dataverse) ──
DATAVERSE_URL=
DATAVERSE_TENANT_ID=
DATAVERSE_CLIENT_ID=
DATAVERSE_CLIENT_SECRET=
