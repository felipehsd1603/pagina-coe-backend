# ─── Server ──────────────────────────────────────────
PORT=4000

# ─── Auth Mode ───────────────────────────────────────
# "mock" for local dev, "entra" for production
AUTH_MODE=mock

# ─── Database ────────────────────────────────────────
DATABASE_URL="sqlserver://localhost:1433;database=portal_aegea;user=sa;password=YourStrong!Pass;encrypt=true;trustServerCertificate=true"

# ─── Mock Auth (dev only) ────────────────────────────
MOCK_JWT_SECRET=dev-secret-key-change-in-production

# ─── Microsoft Entra ID (production) ─────────────────
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# ─── CoE Data Source ─────────────────────────────────
# "dataverse" = API real do Dataverse (CoE Starter Kit)
# "local"     = Dados reais AEGEA (telemetria + fichas) - PADRAO
# "mock"      = Dados ficticios para demo
COE_DATA_SOURCE=local

# ─── Dataverse OData (quando COE_DATA_SOURCE=dataverse) ──
# URL do seu org Dataverse (ex: https://org12345.crm2.dynamics.com)
DATAVERSE_URL=
# Tenant ID do Azure AD
DATAVERSE_TENANT_ID=
# App Registration para acesso ao Dataverse
DATAVERSE_CLIENT_ID=
DATAVERSE_CLIENT_SECRET=
