                          "type": "integer"
                        },
                        "totalFlows": {
                          "type": "integer"
                        },
                        "totalMakers": {
                          "type": "integer"
                        },
                        "totalEnvironments": {
                          "type": "integer"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
